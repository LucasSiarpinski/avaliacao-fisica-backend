// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campus {
  id     Int    @id @default(autoincrement())
  name   String @unique
  city   String
  users  User[]
  alunos           Aluno[]
  messageTemplates MessageTemplate[]
}

model User {
  id                Int        @id @default(autoincrement())
  email             String     @unique
  name              String
  password          String
  createdAt         DateTime   @default(now())
  role              UserRole   @default(PROFESSOR)
  status            UserStatus @default(ACTIVE)
  telefone          String?
  cpf               String?    @unique
  matricula         String?    @unique
  foto              String?
  ultimoAcesso      DateTime?
  campusId          Int
  campus            Campus     @relation(fields: [campusId], references: [id])
  alunosCadastrados Aluno[]    @relation("ProfessorAlunos")
}

enum UserRole {
  PROFESSOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Aluno {
  id             Int            @id @default(autoincrement())
  nome           String
  email          String         @unique
  dataNasc       DateTime
  matricula      String         @unique
  cpf            String?        @unique
  genero         String?
  telefone       String?
  endereco       String?
  profissao      String?
  observacoes    String?        @db.Text
  objetivo       ObjetivoAluno  @default(SAUDE)
  status         StatusAluno    @default(ATIVO)
  
  // Controle
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?      // Para Soft Delete (LGPD)

  // Relacionamentos
  campusId       Int
  campus         Campus         @relation(fields: [campusId], references: [id])
  professorId    Int
  professor      User           @relation("ProfessorAlunos", fields: [professorId], references: [id])
  
  anamneses      Anamnese[]
  avaliacoes     Avaliacao[]
  documentos     Documento[]
}

enum ObjetivoAluno {
  EMAGRECIMENTO
  HIPERTROFIA
  CONDICIONAMENTO
  PERFORMANCE
  SAUDE
}

enum StatusAluno {
  ATIVO
  INATIVO
}

// ==========================================
// MÓDULO DE ANAMNESE E SAÚDE
// ==========================================

model Anamnese {
  id                Int       @id @default(autoincrement())
  dataPreenchimento DateTime? @default(now())
  status            AnamneseStatus @default(PENDING)
  termoAceite       Boolean   @default(false)
  
  // Relacionamento 1:N (Um aluno pode ter várias anamneses ao longo do tempo)
  alunoId           Int
  aluno             Aluno     @relation(fields: [alunoId], references: [id])

  // Sub-módulos da Anamnese
  dadosMedicos      DadosMedicos?
  habitos           Habitos?
  parq              ParQ?
}

enum AnamneseStatus {
  PENDING
  COMPLETED
}

model DadosMedicos {
  id                Int       @id @default(autoincrement())
  anamneseId        Int       @unique
  anamnese          Anamnese  @relation(fields: [anamneseId], references: [id], onDelete: Cascade)
  
  hipertensao       Boolean   @default(false)
  diabetes          Boolean   @default(false)
  problemaCardiaco  Boolean   @default(false)
  lesoes            String?   @db.Text
  cirurgias         String?   @db.Text
  medicamentos      String?   @db.Text
  alergias          String?   @db.Text
  restricoes        String?   @db.Text
  observacoes       String?   @db.Text
}

model Habitos {
  id                Int       @id @default(autoincrement())
  anamneseId        Int       @unique
  anamnese          Anamnese  @relation(fields: [anamneseId], references: [id], onDelete: Cascade)
  
  fumante           Boolean   @default(false)
  consomeAlcool     Boolean   @default(false)
  qualidadeSono     String?   // Ex: BOA, REGULAR, RUIM
  nivelEstresse     String?   // Ex: BAIXO, MEDIO, ALTO
  praticaAtividade  Boolean   @default(false)
  tipoAtividade     String?
  alimentacao       String?   @db.Text
}

model ParQ {
  id                Int       @id @default(autoincrement())
  anamneseId        Int       @unique
  anamnese          Anamnese  @relation(fields: [anamneseId], references: [id], onDelete: Cascade)
  
  pergunta1         Boolean   @default(false) // Problema cardíaco
  pergunta2         Boolean   @default(false) // Dor no peito na atividade
  pergunta3         Boolean   @default(false) // Dor no peito no último mês
  pergunta4         Boolean   @default(false) // Desequilíbrio/Tontura
  pergunta5         Boolean   @default(false) // Problema ósseo/articular
  pergunta6         Boolean   @default(false) // Medicamento pressão/coração
  pergunta7         Boolean   @default(false) // Outro impedimento físico
}

// ==========================================
// MÓDULO DE AVALIAÇÃO FÍSICA (Base inicial)
// ==========================================

model Avaliacao {
  id         Int      @id @default(autoincrement())
  data       DateTime @default(now())
  tipo       String
  resultados Json
  deletedAt  DateTime?
  alunoId    Int
  aluno      Aluno    @relation(fields: [alunoId], references: [id])
}

model Documento {
  id       Int      @id @default(autoincrement())
  nome     String
  tipo     String
  url      String
  uploadAt DateTime @default(now())
  alunoId  Int
  aluno    Aluno    @relation(fields: [alunoId], references: [id])
}

// ==========================================
// MÓDULO DE RELATÓRIOS E COMUNICAÇÃO
// ==========================================

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  title     String
  body      String   @db.Text
  campusId  Int
  campus    Campus   @relation(fields: [campusId], references: [id])
  createdAt DateTime @default(now())
}